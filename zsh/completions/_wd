#compdef wd

_wd() {
  local -a engines
  engines=(stardict google)

  _arguments -s \
    '-h[show help]' \
    '--help[show help]' \
    '-e+[choose engine in fallback order]:engine:(${engines})' \
    '--engine+[choose engine in fallback order]:engine:(${engines})' \
    '--list-engines[list available engines]' \
    '--no-say[disable text-to-speech]' \
    '1:word: '
}

_wd "$@"
