#compdef cheat

_cheat() {
  local -a sheets
  local -a options
  local state

  sheets=("${(@f)$(command cheat -l 2>/dev/null | awk '{print $1}')}")

  options=(
    '-d[list directories on CHEAT_PATH]'
    '--directories[list directories on CHEAT_PATH]'
    '-e[edit cheatsheet]'
    '--edit[edit cheatsheet]'
    '-l[list cheatsheets]'
    '--list[list cheatsheets]'
    '-s[search cheatsheets for keyword]'
    '--search[search cheatsheets for keyword]'
    '-q[query online in cheat.sh]'
    '--query[query online in cheat.sh]'
    '-h[show help]'
    '--help[show help]'
    '-v[show version]'
    '--version[show version]'
  )

  case "$words[2]" in
    -e|--edit)
      _describe -t cheatsheets 'cheatsheet' sheets
      return
      ;;
    -s|--search)
      _message 'keyword'
      return
      ;;
    -q|--query)
      _message 'query'
      return
      ;;
  esac

  if (( CURRENT == 2 )); then
    _alternative \
      'options:option:->options' \
      'cheatsheets:cheatsheet:->cheatsheets'
    case $state in
      options)
        _describe -t options 'option' options
        ;;
      cheatsheets)
        _describe -t cheatsheets 'cheatsheet' sheets
        ;;
    esac
    return
  fi

  _arguments -s $options '*:arg: '
}

_cheat "$@"
