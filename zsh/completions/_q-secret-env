#compdef q-secret-env

_q_secret_env_names() {
  local -a names
  names=(${(f)"$(q-secret-env -l 2>/dev/null)"})
  _describe -t env_names 'encrypted env name' names
}

_q_secret_env() {
  _arguments -C -s \
    '--list[list all encrypted env names]' \
    '--dump[list and decrypt all entries]' \
    '--get[decrypt one env entry and print value]:env name:_q_secret_env_names' \
    '--remove[remove one env entry]:env name:_q_secret_env_names' \
    '--rm[remove one env entry]:env name:_q_secret_env_names' \
    '--set[add or update one env entry]:env name:_q_secret_env_names:env value:' \
    '--add[add or update one env entry]:env name:_q_secret_env_names:env value:' \
    '--reset-pass[reset or rotate master password (interactive)]' \
    '--unlock[unlock local access by verifying master password]' \
    '--sync[sync decrypted env file]' \
    '--help[show help]' \
    '-l[list all encrypted env names]' \
    '-d[decrypt one env entry and print value]:env name:_q_secret_env_names' \
    '-r[remove one env entry]:env name:_q_secret_env_names' \
    '-a[add or update one env entry]:env name:_q_secret_env_names:env value:' \
    '-ld[list and decrypt all entries]' \
    '-dl[list and decrypt all entries]' \
    '-h[show help]'
}

_q_secret_env "$@"
