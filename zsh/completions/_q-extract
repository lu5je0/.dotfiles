#compdef q-extract

_q_extract_archives() {
  _files -g '*.(tar|tar.gz|tgz|tar.bz2|tbz2|tar.xz|txz|bz2|rar|gz|zip|jar|Z|7z)'
}

_q_extract() {
  _arguments -C -s \
    '-h[show help]' \
    '--help[show help]' \
    '--output_dir[extract into target directory]:directory:_files -/' \
    '1:archive:_q_extract_archives'
}

_q_extract "$@"
