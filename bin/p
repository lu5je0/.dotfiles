#!/usr/bin/env bash

set -euo pipefail

WCLIP="$(dirname "$(realpath "${BASH_SOURCE[0]}")")/../win/bin/wclip.exe"

usage() {
  cat <<'EOF'
Usage: p [options]

Paste clipboard content to stdout.

Options:
  -f    Force output even if stdout is a terminal (for binary data)
  -h    Show this help message

Examples:
  p              Paste text
  p > 1.png      Save clipboard image to file
  p | vv         Display clipboard image in terminal
  p -f           Force binary output to terminal
EOF
  exit 0
}

force=0
while getopts "fh" opt; do
  case $opt in
    f) force=1 ;;
    h) usage ;;
    *) usage ;;
  esac
done

if [[ -n ${SSH_CLIENT:-}${SSH_TTY:-} ]] && command -v _clipboard_osc52 >/dev/null 2>&1; then
  exec _clipboard_osc52 paste
fi

uname_info=$(uname -a)

if [[ $uname_info == *Darwin* ]] && command -v mac_clipboard_cli >/dev/null 2>&1; then
  exec mac_clipboard_cli -p
fi

if [[ $uname_info == *WSL* ]]; then
  # If stdout is not a terminal or force is set, skip detect and paste directly
  if [[ ! -t 1 ]] || (( force )); then
    exec "$WCLIP" paste
  fi

  # stdout is a terminal without -f, detect type to block binary
  cb_type=$("$WCLIP" paste --detect | tr -d '\r\n')
  case $cb_type in
    image|file)
      printf 'p: clipboard contains %s data, use -f to force output or redirect to a file\n' "$cb_type" >&2
      exit 1
      ;;
    text)
      exec "$WCLIP" paste
      ;;
    *)
      printf 'p: clipboard is empty\n' >&2
      exit 1
      ;;
  esac
fi

printf 'p: clipboard backend unavailable\n' >&2
exit 1
