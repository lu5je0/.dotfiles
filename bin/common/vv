#!/usr/bin/env python3
import sys
import os
import subprocess
import struct
import json
import shutil
import time
from base64 import standard_b64encode

def is_kitty():
    return os.environ.get('TERM') == 'xterm-kitty'

def is_tmux():
    return bool(os.environ.get('TMUX')) or \
        os.environ.get('TERM', '').startswith(('tmux', 'screen'))

def is_wsl_wezterm():
    return (os.path.exists('/proc/sys/fs/binfmt_misc/WSLInterop') and
            os.environ.get('TERM_PROGRAM') == 'WezTerm')

def find_wezterm_exe():
    exe = shutil.which('wezterm.exe')
    if exe:
        return exe
    win_home = os.environ.get('WIN_HOME')
    if win_home:
        path = os.path.join(win_home, 'scoop', 'shims', 'wezterm.exe')
        if os.path.isfile(path):
            return path
    return None

def get_wezterm_pane_size():
    exe = find_wezterm_exe()
    if not exe:
        return None
    try:
        result = subprocess.run([exe, 'cli', 'list', '--format', 'json'],
                                capture_output=True, text=True, timeout=2)
        if result.returncode != 0:
            return None
        panes = json.loads(result.stdout)
    except Exception:
        return None

    try:
        term = os.get_terminal_size()
    except OSError:
        return None

    best, best_score = None, -1
    for pane in panes:
        size = pane.get('size') or {}
        pw, ph = size.get('pixel_width', 0), size.get('pixel_height', 0)
        pc, pr = size.get('cols', 0), size.get('rows', 0)
        if pw > 0 and ph > 0 and pc > 0 and pr > 0:
            score = ((2 if pc == term.columns else 0) +
                     (2 if pr == term.lines else 0) +
                     (1 if pane.get('is_active') else 0))
            if score > best_score:
                best = {'cols': pc, 'rows': pr, 'pw': pw, 'ph': ph}
                best_score = score
    return best

def get_image_dimensions(data):
    # PNG
    if len(data) > 24 and data[:8] == b'\x89PNG\r\n\x1a\n':
        return struct.unpack('>II', data[16:24])
    # JPEG
    if len(data) > 2 and data[:2] == b'\xff\xd8':
        i = 2
        while i < len(data) - 9:
            if data[i] != 0xff:
                break
            marker = data[i + 1]
            if marker in (0xc0, 0xc1, 0xc2):
                h, w = struct.unpack('>HH', data[i + 5:i + 9])
                return w, h
            if i + 4 > len(data):
                break
            length = struct.unpack('>H', data[i + 2:i + 4])[0]
            i += 2 + length
    return None, None

def tmux_passthrough(seq):
    # tmux 需要 passthrough DCS 包裹，且内部 ESC 要加倍
    return b'\033Ptmux;' + seq.replace(b'\033', b'\033\033') + b'\033\\'

def serialize_gr_command(**cmd):
    payload = cmd.pop('payload', None)
    cmd = ','.join(f'{k}={v}' for k, v in cmd.items())
    ans = []
    w = ans.append
    w(b'\033_G'), w(cmd.encode('ascii'))
    if payload:
        w(b';')
        w(payload)
    w(b'\033\\')
    return b''.join(ans)

def write_chunked(**cmd):
    data = standard_b64encode(cmd.pop('data'))
    wrap = is_tmux()
    while data:
        chunk, data = data[:4096], data[4096:]
        m = 1 if data else 0
        seq = serialize_gr_command(payload=chunk, m=m, **cmd)
        if wrap:
            seq = tmux_passthrough(seq)
        sys.stdout.buffer.write(seq)
        sys.stdout.flush()
        cmd.clear()

def get_terminal_pixel_size():
    try:
        import fcntl
        import termios
        buf = fcntl.ioctl(sys.stdout.fileno(), termios.TIOCGWINSZ, b'\0' * 8)
        _rows, _cols, xpix, ypix = struct.unpack('HHHH', buf)
        if xpix > 0 and ypix > 0:
            return xpix, ypix
    except Exception:
        pass
    return None

def maybe_downscale(image_data):
    size = get_terminal_pixel_size()
    max_w, max_h = size if size else (1920, 1920)
    img_w, img_h = get_image_dimensions(image_data)
    if img_w and img_h and img_w <= max_w and img_h <= max_h:
        return image_data
    magick = shutil.which('magick') or shutil.which('convert')
    if not magick:
        return image_data
    try:
        result = subprocess.run(
            [magick, '-', '-resize', f'{max_w}x{max_h}>', 'png:-'],
            input=image_data, capture_output=True, timeout=10)
        if result.returncode == 0 and result.stdout:
            return result.stdout
    except Exception:
        pass
    return image_data

def get_tmux_cell_size():
    try:
        result = subprocess.run(
            ['tmux', 'display-message', '-p',
             '#{client_cell_width},#{client_cell_height}'],
            capture_output=True, text=True, timeout=2)
        w, h = result.stdout.strip().split(',')
        w, h = int(w), int(h)
        if w > 0 and h > 0:
            return w, h
    except Exception:
        pass
    return 8, 16

def get_tmux_pane_position():
    try:
        result = subprocess.run(
            ['tmux', 'display-message', '-p', '-t',
             os.environ.get('TMUX_PANE', ''),
             '#{pane_top},#{pane_left},#{cursor_y},#{cursor_x},'
             '#{status},#{status-position}'],
            capture_output=True, text=True, timeout=2)
        top, left, cy, cx, status, status_pos = \
            result.stdout.strip().split(',')
        top, left, cy, cx = int(top), int(left), int(cy), int(cx)
        if status_pos == 'top' and status != 'off':
            top += 1 if status == 'on' else int(status)
        return top, left, cy, cx
    except Exception:
        return None

def display_tmux(image_data):
    img_w, img_h = get_image_dimensions(image_data)
    if not (img_w and img_h):
        write_chunked(a='T', f=100, data=image_data)
        return
    cw, ch = get_tmux_cell_size()
    try:
        term = os.get_terminal_size()
        max_cols, max_rows = term.columns, max(1, term.lines - 2)
    except OSError:
        max_cols, max_rows = 80, 22
    scale = min(max_cols * cw / img_w, max_rows * ch / img_h, 1.0)
    cols = max(1, int(img_w * scale / cw))
    rows = max(1, int((img_h * scale + ch - 1) / ch))

    img_id = os.getpid() % 0xFFFFFF + 1

    # 预留行数，让 tmux 先滚动出图片空间
    sys.stdout.write('\n' * rows)
    sys.stdout.flush()
    time.sleep(0.05)

    # 只传输数据不显示（q=2 抑制应答，避免污染 tmux）
    write_chunked(a='t', f=100, i=img_id, q=2, data=image_data)

    pos = get_tmux_pane_position()
    place = serialize_gr_command(a='p', i=img_id, C=1,
                                 c=cols, r=rows, q=2)
    if pos:
        top, left, cy, cx = pos
        row = top + cy - rows + 1  # 1-based 绝对行
        col = left + 1
        # 在同一个 passthrough 中完成: 存光标 -> 绝对定位 -> 放置 -> 还原光标
        inner = (b'\0337' + f'\033[{row};{col}H'.encode('ascii') +
                 place + b'\0338')
    else:
        inner = place
    sys.stdout.buffer.write(tmux_passthrough(inner))
    sys.stdout.flush()

def display_image(image_data):
    if is_kitty():
        # 使用subprocess.Popen来创建一个管道
        p = subprocess.Popen(['kitty', '+kitten', 'icat'], stdin=subprocess.PIPE)
        p.communicate(input=image_data)
    else:
        image_data = maybe_downscale(image_data)
        if is_tmux():
            display_tmux(image_data)
            return
        extra = {}
        if is_wsl_wezterm():
            pane = get_wezterm_pane_size()
            if pane:
                img_w, img_h = get_image_dimensions(image_data)
                if img_w and img_h:
                    cell_w = pane['pw'] / pane['cols']
                    cell_h = pane['ph'] / pane['rows']
                    max_cols = pane['cols']
                    scale = min(max_cols * cell_w / img_w, 1.0)
                    extra['c'] = max(1, int(img_w * scale / cell_w))
                    extra['r'] = max(1, int(img_h * scale / cell_h))
        write_chunked(a='T', f=100, data=image_data, **extra)

if __name__ == "__main__":
    # 检查是否有数据从管道输入
    if not sys.stdin.isatty():
        # 从标准输入读取数据
        image_data = sys.stdin.buffer.read()
    elif len(sys.argv) > 1:
        # 如果提供了文件路径，则从文件读取数据
        with open(sys.argv[1], 'rb') as f:
            image_data = f.read()
    else:
        print("Please provide an image file path or pipe image data.")
        sys.exit(1)
    
    display_image(image_data)

