#!/usr/bin/env bash

set -euo pipefail

: "${DOTFILES_DIR:=$HOME/.dotfiles}"
WCLIP="$DOTFILES_DIR/bin/windows-x86_64/wclip.exe"

if [[ -n ${SSH_CLIENT:-}${SSH_TTY:-} ]] && command -v clipboard-osc52 >/dev/null 2>&1; then
  exec clipboard-osc52 copy
fi

uname_info=$(uname -a)

if [[ $uname_info == *Darwin* ]] && command -v mac_clipboard_cli >/dev/null 2>&1; then
  exec mac_clipboard_cli -c
fi

if [[ $uname_info == *WSL* ]]; then
  exec "$WCLIP" copy
fi

printf 'yy: clipboard backend unavailable\n' >&2
exit 1
