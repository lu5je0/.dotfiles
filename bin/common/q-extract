#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  q-extract -h | --help
  q-extract <archive> [--output_dir <dir>]

Examples:
  q-extract archive.zip
  q-extract archive.tar.gz --output_dir extracted/
EOF
}

archive=""
output_dir=""
output_dir_specified=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --output_dir)
      if [[ $# -lt 2 ]]; then
        echo "q-extract: missing value for --output_dir" >&2
        exit 1
      fi
      output_dir="$2"
      output_dir_specified=1
      shift 2
      ;;
    --output_dir=*)
      output_dir="${1#*=}"
      output_dir_specified=1
      shift
      ;;
    -*)
      echo "q-extract: unknown option '$1'" >&2
      usage >&2
      exit 1
      ;;
    *)
      if [[ -n "$archive" ]]; then
        echo "q-extract: only one archive file is supported" >&2
        usage >&2
        exit 1
      fi
      archive="$1"
      shift
      ;;
  esac
done

if [[ -z "$archive" ]]; then
  usage >&2
  exit 1
fi

if [[ ! -f "$archive" ]]; then
  echo "q-extract: '$archive' is not a valid file" >&2
  exit 1
fi

if [[ $output_dir_specified -eq 1 && -z "$output_dir" ]]; then
  echo "q-extract: --output_dir cannot be empty" >&2
  exit 1
fi

archive_path="$(realpath "$archive")"
restore_dir=""

single_file_output_path() {
  local suffix="$1"
  local archive_name
  local output_name
  local output_base

  archive_name="$(basename "$archive_path")"
  output_name="${archive_name%$suffix}"

  if [[ "$output_name" == "$archive_name" ]]; then
    echo "q-extract: failed to derive output name for '$archive'" >&2
    return 1
  fi

  if [[ -n "$output_dir" ]]; then
    output_base="$(realpath "$output_dir")"
  else
    output_base="$(dirname "$archive_path")"
  fi

  printf '%s/%s\n' "$output_base" "$output_name"
}

extract_single_file_to_path() {
  local suffix="$1"
  local command_name="$2"
  local destination

  destination="$(single_file_output_path "$suffix")" || return 1

  if [[ -e "$destination" ]]; then
    echo "q-extract: target already exists: '$destination'" >&2
    return 1
  fi

  case "$command_name" in
    gunzip) gunzip -c "$archive_path" > "$destination" ;;
    bunzip2) bunzip2 -c "$archive_path" > "$destination" ;;
    uncompress) uncompress -c "$archive_path" > "$destination" ;;
    *)
      echo "q-extract: unsupported extractor '$command_name'" >&2
      return 1
      ;;
  esac
}

extract_archive() {
  case "$archive_path" in
    *.tar.bz2|*.tbz2) tar -xvjf "$archive_path" ;;
    *.tar.gz|*.tgz) tar -xvzf "$archive_path" ;;
    *.tar.xz|*.txz) tar -xvJf "$archive_path" ;;
    *.tar) tar -xvf "$archive_path" ;;
    *.bz2) extract_single_file_to_path '.bz2' bunzip2 ;;
    *.rar) rar x "$archive_path" ;;
    *.gz) extract_single_file_to_path '.gz' gunzip ;;
    *.zip|*.jar) unzip -o "$archive_path" ;;
    *.Z) extract_single_file_to_path '.Z' uncompress ;;
    *.7z) 7z x "$archive_path" ;;
    *)
      echo "q-extract: don't know how to extract '$archive'" >&2
      return 1
      ;;
  esac
}

if [[ -n "$output_dir" ]]; then
  mkdir -p "$output_dir"
  restore_dir="$PWD"
  cd "$output_dir"
fi

extract_archive

if [[ -n "$restore_dir" ]]; then
  cd "$restore_dir"
fi
