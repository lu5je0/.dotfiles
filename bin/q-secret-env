#!/usr/bin/env bash
set -euo pipefail

INSTALL_PATH="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
DOTFILES_DIR="${DOTFILES_DIR:-$(realpath "${INSTALL_PATH}/..")}"

REPO_SECRETS_DIR="${DOTFILES_DIR}/secrets"
ENC_FILE="${REPO_SECRETS_DIR}/q-secret-env.enc"
ENC_FILE_MAGIC="QSENVENC1"

LEGACY_CONF_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/lu5je0/q-secret-env"
CONF_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/q-secret-env"
PASS_FILE="${CONF_DIR}/master.pass"
ENV_FILE="${CONF_DIR}/env.zsh"

usage() {
  cat <<'EOF'
Usage:
  q-secret-env -l | --list
  q-secret-env -a NAME value | --set NAME value
  q-secret-env -d NAME | --get NAME
  q-secret-env -r NAME | --remove NAME
  q-secret-env -d -l | -ld | --dump

Options:
  -l, --list            List all encrypted env names.
  -a, --add NAME value  Add or update one env entry.
  -d, --get NAME        Decrypt one env entry and print value.
  -r, --remove NAME     Remove one env entry.
  --dump                List and decrypt all entries.
  -h, --help            Show this help.

Notes:
  - Encrypted data is stored in repo: ~/.dotfiles/secrets/q-secret-env.enc
  - A derived secret key is stored locally: ~/.config/q-secret-env/master.pass
  - Decrypted exports are written to: ~/.config/q-secret-env/env.zsh
EOF
}

migrate_config_dir_if_needed() {
  if [[ -d "${LEGACY_CONF_DIR}" && "${LEGACY_CONF_DIR}" != "${CONF_DIR}" ]]; then
    mkdir -p "${CONF_DIR}"

    if [[ -f "${LEGACY_CONF_DIR}/master.pass" && ! -f "${CONF_DIR}/master.pass" ]]; then
      mv "${LEGACY_CONF_DIR}/master.pass" "${CONF_DIR}/master.pass"
    fi

    if [[ -f "${LEGACY_CONF_DIR}/env.zsh" && ! -f "${CONF_DIR}/env.zsh" ]]; then
      mv "${LEGACY_CONF_DIR}/env.zsh" "${CONF_DIR}/env.zsh"
    fi

    rmdir "${LEGACY_CONF_DIR}" 2>/dev/null || true
  fi
}

ensure_dirs() {
  migrate_config_dir_if_needed
  mkdir -p "${REPO_SECRETS_DIR}" "${CONF_DIR}"
  chmod 700 "${CONF_DIR}" 2>/dev/null || true
}

b64_encode() {
  printf '%s' "$1" | base64 | tr -d '\n'
}

b64_decode() {
  local input="$1"
  if printf '%s' "${input}" | base64 --decode >/dev/null 2>&1; then
    printf '%s' "${input}" | base64 --decode
  else
    printf '%s' "${input}" | base64 -d
  fi
}

derive_key_hex() {
  local pass="$1"
  local salt_hex="$2"
  local iter="$3"
  local out key_hex

  out="$(openssl enc -aes-256-cbc -pbkdf2 -iter "${iter}" -P -pass "pass:${pass}" -S "${salt_hex}" 2>/dev/null)"
  key_hex="$(printf '%s\n' "${out}" | awk -F= '$1=="key"{print $2}')"
  if [[ -z "${key_hex}" ]]; then
    echo "Failed to derive key."
    return 1
  fi
  printf '%s' "${key_hex}"
}

get_secret_phrase() {
  local line salt_hex iter key_hex legacy_pass
  line="$(head -n 1 "${PASS_FILE}" 2>/dev/null || true)"

  # New format: QSENV1:<salt_hex>:<iter>:<key_hex>
  if [[ "${line}" == QSENV1:* ]]; then
    IFS=':' read -r _tag salt_hex iter key_hex <<< "${line}"
    if [[ -z "${key_hex}" ]]; then
      echo "Invalid pass file format."
      return 1
    fi
    printf 'QSENV1-%s' "${key_hex}"
    return 0
  fi

  # Legacy format fallback.
  legacy_pass="${line}"
  if [[ -z "${legacy_pass}" ]]; then
    echo "Invalid pass file."
    return 1
  fi
  printf '%s' "${legacy_pass}"
}

migrate_legacy_pass_file_if_needed() {
  local line legacy_pass salt_hex iter key_hex new_phrase
  line="$(head -n 1 "${PASS_FILE}" 2>/dev/null || true)"
  if [[ -z "${line}" || "${line}" == QSENV1:* ]]; then
    return 0
  fi

  legacy_pass="${line}"
  salt_hex="$(openssl rand -hex 8)"
  iter="200000"
  key_hex="$(derive_key_hex "${legacy_pass}" "${salt_hex}" "${iter}")"
  new_phrase="QSENV1-${key_hex}"

  if [[ -f "${ENC_FILE}" ]]; then
    local tmp_db tmp_enc
    tmp_db="$(mktemp)"
    tmp_enc="$(mktemp)"

    if ! openssl enc -d -aes-256-cbc -pbkdf2 \
      -pass "pass:${legacy_pass}" \
      -in "${ENC_FILE}" \
      -out "${tmp_db}" 2>/dev/null; then
      rm -f "${tmp_db}" "${tmp_enc}"
      echo "Failed to migrate legacy pass file: cannot decrypt existing encrypted db."
      return 1
    fi

    openssl enc -aes-256-cbc -pbkdf2 -salt \
      -pass "pass:${new_phrase}" \
      -in "${tmp_db}" \
      -out "${tmp_enc}"
    mv "${tmp_enc}" "${ENC_FILE}"
    chmod 600 "${ENC_FILE}" 2>/dev/null || true
    rm -f "${tmp_db}"
  fi

  printf 'QSENV1:%s:%s:%s\n' "${salt_hex}" "${iter}" "${key_hex}" > "${PASS_FILE}"
  chmod 600 "${PASS_FILE}" 2>/dev/null || true
}

ensure_password() {
  local non_interactive="${1:-0}"
  ensure_dirs

  if [[ -s "${PASS_FILE}" ]]; then
    migrate_legacy_pass_file_if_needed
    chmod 600 "${PASS_FILE}" 2>/dev/null || true
    return 0
  fi

  if [[ "${non_interactive}" == "1" ]]; then
    return 1
  fi

  local pass1=""
  local pass2=""
  echo "q-secret-env first use: set master password."
  read -rsp "Password: " pass1
  echo
  read -rsp "Confirm: " pass2
  echo

  if [[ -z "${pass1}" ]]; then
    echo "Password cannot be empty."
    return 1
  fi
  if [[ "${pass1}" != "${pass2}" ]]; then
    echo "Password mismatch."
    return 1
  fi

  local salt_hex iter key_hex
  salt_hex="$(openssl rand -hex 8)"
  iter="200000"
  key_hex="$(derive_key_hex "${pass1}" "${salt_hex}" "${iter}")"
  printf 'QSENV1:%s:%s:%s\n' "${salt_hex}" "${iter}" "${key_hex}" > "${PASS_FILE}"
  chmod 600 "${PASS_FILE}"
}

decrypt_db_to_file() {
  local out_file="$1"
  local secret_phrase
  local first_line
  local tmp_enc_bin
  secret_phrase="$(get_secret_phrase)"
  : > "${out_file}"

  if [[ ! -f "${ENC_FILE}" ]]; then
    return 0
  fi

  first_line="$(head -n 1 "${ENC_FILE}" 2>/dev/null || true)"
  if [[ "${first_line}" == "${ENC_FILE_MAGIC}" ]]; then
    tmp_enc_bin="$(mktemp)"
    tail -n +2 "${ENC_FILE}" | tr -d '\n' | openssl base64 -d -A -out "${tmp_enc_bin}"

    if ! openssl enc -d -aes-256-cbc -pbkdf2 \
      -pass "pass:${secret_phrase}" \
      -in "${tmp_enc_bin}" \
      -out "${out_file}" 2>/dev/null; then
      rm -f "${tmp_enc_bin}"
      echo "Failed to decrypt ${ENC_FILE}. Check password file."
      return 1
    fi
    rm -f "${tmp_enc_bin}"
    return 0
  fi

  # Legacy binary format fallback; auto-migrate to text format after successful decrypt.
  if openssl enc -d -aes-256-cbc -pbkdf2 \
    -pass "pass:${secret_phrase}" \
    -in "${ENC_FILE}" \
    -out "${out_file}" 2>/dev/null; then
    encrypt_db_from_file "${out_file}"
    return 0
  fi

  echo "Failed to decrypt ${ENC_FILE}. Check password file."
  return 1
}

encrypt_db_from_file() {
  local in_file="$1"
  local secret_phrase
  local tmp_enc_bin
  local tmp_enc_txt
  secret_phrase="$(get_secret_phrase)"

  tmp_enc_bin="$(mktemp)"
  tmp_enc_txt="$(mktemp)"

  openssl enc -aes-256-cbc -pbkdf2 -salt \
    -pass "pass:${secret_phrase}" \
    -in "${in_file}" \
    -out "${tmp_enc_bin}"

  {
    printf '%s\n' "${ENC_FILE_MAGIC}"
    openssl base64 -A -in "${tmp_enc_bin}"
    printf '\n'
  } > "${tmp_enc_txt}"

  mv "${tmp_enc_txt}" "${ENC_FILE}"
  rm -f "${tmp_enc_bin}"
  chmod 600 "${ENC_FILE}" 2>/dev/null || true
}

write_env_file_from_db() {
  local db_file="$1"
  local tmp_env
  local env_key
  local env_b64
  local env_value
  tmp_env="$(mktemp)"

  while IFS=$'\t' read -r env_key env_b64 || [[ -n "${env_key:-}" ]]; do
    [[ -z "${env_key}" ]] && continue
    [[ -z "${env_b64:-}" ]] && continue
    env_value="$(b64_decode "${env_b64}")"
    printf 'export %s=%q\n' "${env_key}" "${env_value}" >> "${tmp_env}"
  done < "${db_file}"

  mv "${tmp_env}" "${ENV_FILE}"
  chmod 600 "${ENV_FILE}" 2>/dev/null || true
}

sync_all() {
  if ! ensure_password 1; then
    return 0
  fi

  local db_file
  db_file="$(mktemp)"
  decrypt_db_to_file "${db_file}"
  write_env_file_from_db "${db_file}"
  rm -f "${db_file}"
}

add_entry() {
  local key="$1"
  local value="$2"
  if [[ ! "${key}" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
    echo "Invalid env name: ${key}"
    return 1
  fi

  ensure_password 0

  local db_file new_db b64
  db_file="$(mktemp)"
  new_db="$(mktemp)"
  decrypt_db_to_file "${db_file}"

  b64="$(b64_encode "${value}")"

  awk -F'\t' -v key="${key}" -v b64="${b64}" '
    BEGIN { updated = 0 }
    $1 == key { print key "\t" b64; updated = 1; next }
    { print }
    END { if (updated == 0) print key "\t" b64 }
  ' "${db_file}" > "${new_db}"

  encrypt_db_from_file "${new_db}"
  write_env_file_from_db "${new_db}"
  echo "Saved: ${key}"
  rm -f "${db_file}" "${new_db}"
}

list_entries() {
  if ! ensure_password 1; then
    return 0
  fi

  local db_file
  db_file="$(mktemp)"
  decrypt_db_to_file "${db_file}"
  write_env_file_from_db "${db_file}"

  if [[ ! -s "${db_file}" ]]; then
    rm -f "${db_file}"
    return 0
  fi

  awk -F'\t' '{ if ($1 != "") print $1 }' "${db_file}"
  rm -f "${db_file}"
}

decrypt_one() {
  local key="$1"

  if [[ ! "${key}" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
    echo "Invalid env name: ${key}"
    return 1
  fi

  ensure_password 0

  local db_file line b64 value
  db_file="$(mktemp)"
  decrypt_db_to_file "${db_file}"

  line="$(awk -F'\t' -v key="${key}" '$1 == key { print $0; exit }' "${db_file}")"
  if [[ -z "${line}" ]]; then
    echo "Not found: ${key}"
    return 1
  fi

  b64="${line#*$'\t'}"
  value="$(b64_decode "${b64}")"
  write_env_file_from_db "${db_file}"
  printf '%s\n' "${value}"
  rm -f "${db_file}"
}

remove_entry() {
  local key="$1"
  local db_file new_db

  if [[ ! "${key}" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
    echo "Invalid env name: ${key}"
    return 1
  fi

  ensure_password 0

  db_file="$(mktemp)"
  new_db="$(mktemp)"
  decrypt_db_to_file "${db_file}"

  if ! awk -F'\t' -v key="${key}" '$1 == key { found = 1 } END { exit(found ? 0 : 1) }' "${db_file}"; then
    rm -f "${db_file}" "${new_db}"
    echo "Not found: ${key}"
    return 1
  fi

  awk -F'\t' -v key="${key}" '$1 != key { print $0 }' "${db_file}" > "${new_db}"
  encrypt_db_from_file "${new_db}"
  write_env_file_from_db "${new_db}"
  rm -f "${db_file}" "${new_db}"
  echo "Removed: ${key}"
}

list_and_decrypt_all() {
  ensure_password 0

  local db_file key b64 value
  db_file="$(mktemp)"
  decrypt_db_to_file "${db_file}"
  write_env_file_from_db "${db_file}"

  while IFS=$'\t' read -r key b64 || [[ -n "${key:-}" ]]; do
    [[ -z "${key}" ]] && continue
    [[ -z "${b64:-}" ]] && continue
    value="$(b64_decode "${b64}")"
    printf '%s\t%s\n' "${key}" "${value}"
  done < "${db_file}"

  rm -f "${db_file}"
}

main() {
  local action=""
  local list_flag=0
  local decrypt_flag=0
  local key=""
  local value=""

  if [[ $# -eq 0 ]]; then
    usage
    return 1
  fi

  while [[ $# -gt 0 ]]; do
    case "${1}" in
      --sync)
        action="sync"
        shift
        ;;
      --dump)
        action="dump"
        shift
        ;;
      -ld|-dl)
        action="dump"
        shift
        ;;
      -l|--list)
        list_flag=1
        shift
        ;;
      -d|--get)
        if [[ $# -ge 2 && "${2}" != -* ]]; then
          action="get"
          key="${2}"
          shift 2
        else
          decrypt_flag=1
          shift
        fi
        ;;
      -a|--add|--set)
        if [[ $# -lt 3 ]]; then
          echo "${1} expects: NAME value"
          usage
          return 1
        fi
        action="set"
        key="${2}"
        value="${3}"
        shift 3
        ;;
      -r|--remove|--rm)
        if [[ $# -lt 2 ]]; then
          echo "${1} expects: NAME"
          usage
          return 1
        fi
        action="remove"
        key="${2}"
        shift 2
        ;;
      -h|--help)
        usage
        return 0
        ;;
      --)
        shift
        break
        ;;
      *)
        echo "Unknown option/arg: ${1}"
        usage
        return 1
        ;;
    esac
  done

  if [[ $# -gt 0 ]]; then
    echo "Unexpected extra args: $*"
    usage
    return 1
  fi

  if [[ -z "${action}" && ${list_flag} -eq 1 && ${decrypt_flag} -eq 1 ]]; then
    action="dump"
  elif [[ -z "${action}" && ${list_flag} -eq 1 ]]; then
    action="list"
  fi

  case "${action}" in
    sync)
      sync_all
      ;;
    dump)
      list_and_decrypt_all
      ;;
    list)
      list_entries
      ;;
    set)
      add_entry "${key}" "${value}"
      ;;
    get)
      decrypt_one "${key}"
      ;;
    remove)
      remove_entry "${key}"
      ;;
    *)
      usage
      return 1
      ;;
  esac
}

main "$@"
