#!/usr/bin/env bash

set -euo pipefail

POWERSHELL='/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe'

if [[ -n ${SSH_CLIENT:-}${SSH_TTY:-} ]] && command -v _clipboard_osc52 >/dev/null 2>&1; then
  exec _clipboard_osc52 copy
fi

uname_info=$(uname -a)

if [[ $uname_info == *Darwin* ]] && command -v mac_clipboard_cli >/dev/null 2>&1; then
  exec mac_clipboard_cli -c
fi

if [[ $uname_info == *WSL* ]]; then
  tmp=$(mktemp)
  trap 'rm -f "$tmp"' EXIT
  cat > "$tmp"

  # Check magic bytes for image formats
  header=$(xxd -l 4 -p "$tmp")

  if [[ $header == 89504e47* ]] || [[ $header == ffd8ff* ]]; then
    # Image data - copy as image to clipboard
    win_path=$(wslpath -w "$tmp")
    "$POWERSHELL" -NoProfile -Command "
      Add-Type -AssemblyName System.Windows.Forms
      Add-Type -AssemblyName System.Drawing
      \$img = [System.Drawing.Image]::FromFile('$win_path')
      [System.Windows.Forms.Clipboard]::SetImage(\$img)
    "
  elif command -v win32yank.exe >/dev/null 2>&1; then
    win32yank.exe -i < "$tmp"
  else
    "$POWERSHELL" -NoProfile -Command "
      Add-Type -AssemblyName System.Windows.Forms
      \$text = [System.IO.File]::ReadAllText('$(wslpath -w "$tmp")')
      [System.Windows.Forms.Clipboard]::SetText(\$text)
    "
  fi
  exit 0
fi

printf 'yy: clipboard backend unavailable\n' >&2
exit 1
